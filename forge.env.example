# Multi-Tenant Environment Configuration for Laravel Forge
# Copy this to your .env file on the production server

# Application Settings
APP_NAME="HomeLogic360"
APP_ENV=production
APP_KEY=base64:YOUR_APP_KEY_HERE
APP_DEBUG=false
APP_TIMEZONE=America/Los_Angeles
APP_URL=https://your-domain.com

# Multi-Tenant Configuration
# If using subdomain routing, uncomment and configure:
# SESSION_DOMAIN=.your-domain.com
# SANCTUM_STATEFUL_DOMAINS=your-domain.com,*.your-domain.com

# Database Configuration (MySQL for production)
# Note: SQLite is suitable for development but MySQL/PostgreSQL is required for production
# See docs/DATABASE_MIGRATION_GUIDE.md for migration instructions
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=evergreen_production
DB_USERNAME=forge
DB_PASSWORD=YOUR_DB_PASSWORD_HERE
# Optional: Enable persistent connections for high-traffic scenarios
# DB_PERSISTENT=false

# File Storage (for facility logo uploads)
FILESYSTEM_DISK=public

# Session Configuration (use database for multi-tenant)
SESSION_DRIVER=database
SESSION_LIFETIME=240
SANCTUM_TOKEN_EXPIRATION=240
SESSION_ENCRYPT=false

# Cache Configuration
# Recommended: Use 'redis' for production for better performance
# Use 'file' for single-server deployments, 'redis' for multi-server or high-performance needs
CACHE_STORE=redis
CACHE_PREFIX=

# Queue Configuration
# Recommended: Use 'redis' for production for better performance and reliability
QUEUE_CONNECTION=redis

# Mail Configuration
# Default mailer - can be overridden per facility in settings
# Options: smtp, ses, ses-v2, sendmail, log, mailgun, postmark
MAIL_MAILER=ses-v2

# SMTP Configuration (if using SMTP mailer)
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null

# Default From Address (can be overridden per facility)
MAIL_FROM_ADDRESS="noreply@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

# Amazon SES Configuration (Global - used by all facilities)
# These credentials are shared across all facilities
# Each facility can configure their own from address/name and optionally override region
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_DEFAULT_REGION=us-east-1
# Optional: SES Configuration Set for tracking and analytics
# AWS_SES_CONFIGURATION_SET=your-config-set-name

# Logging
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# Security
BCRYPT_ROUNDS=12

# Broadcasting Configuration (Real-time Features)
# Set to 'pusher' to enable real-time updates via Pusher
# Set to 'null' to disable broadcasting
BROADCAST_CONNECTION=pusher

# Pusher Configuration
# Get these credentials from https://pusher.com
# Create an app at https://dashboard.pusher.com
PUSHER_APP_ID=your_pusher_app_id
PUSHER_APP_KEY=your_pusher_app_key
PUSHER_APP_SECRET=your_pusher_app_secret
PUSHER_APP_CLUSTER=us2
# Optional: Custom Pusher host (leave empty to use default)
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https

# Frontend Pusher Configuration (Vite)
# These variables are exposed to the frontend during build
# Must have VITE_ prefix to be accessible in React
VITE_PUSHER_APP_KEY=your_pusher_app_key
VITE_PUSHER_APP_CLUSTER=us2
VITE_PUSHER_HOST=
VITE_PUSHER_PORT=443
VITE_PUSHER_SCHEME=https

# Web Push (PWA) — device notifications when the app is in the background
# Generate on a machine with PHP: php artisan webpush:vapid
# Copy public key to both VAPID_PUBLIC_KEY and VITE_VAPID_PUBLIC_KEY; private key stays server-only.
# Run npm run build after setting VITE_VAPID_PUBLIC_KEY, then deploy.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@your-domain.com
VITE_VAPID_PUBLIC_KEY=
