# Multi-Tenant Environment Configuration for Laravel Forge
# Copy this to your .env file on the production server

# Application Settings
APP_NAME="HomeLogic360"
APP_ENV=production
APP_KEY=base64:YOUR_APP_KEY_HERE
APP_DEBUG=false
APP_TIMEZONE=America/Los_Angeles
APP_URL=https://your-domain.com

# Multi-Tenant Configuration
# If using subdomain routing, uncomment and configure:
# SESSION_DOMAIN=.your-domain.com
# SANCTUM_STATEFUL_DOMAINS=your-domain.com,*.your-domain.com

# Database Configuration (MySQL for production)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=evergreen_production
DB_USERNAME=forge
DB_PASSWORD=YOUR_DB_PASSWORD_HERE

# File Storage (for facility logo uploads)
FILESYSTEM_DISK=public

# Session Configuration (use database for multi-tenant)
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false

# Cache Configuration
CACHE_STORE=database
CACHE_PREFIX=

# Queue Configuration
QUEUE_CONNECTION=database

# Mail Configuration
MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

# Logging
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# Security
BCRYPT_ROUNDS=12
