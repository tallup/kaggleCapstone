# -----------------------------------------------
# Application Settings
# -----------------------------------------------
APP_NAME="Evergreen Oasis Care Home"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/Los_Angeles
APP_URL=http://localhost:8000

# Tenant subdomains: set to the same host you use in the browser (e.g. homelogic360.net or localhost for *.localhost dev).
# FACILITY_BASE_DOMAIN=localhost

# -----------------------------------------------
# Database Configuration
# -----------------------------------------------
DB_CONNECTION=sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=/absolute/path/to/database.sqlite
DB_USERNAME=root
DB_PASSWORD=

# Automatic database backups (files in storage/app/backups; download from Super Admin → Database)
# Requires Laravel scheduler: * * * * * cd /path-to-app && php artisan schedule:run
AUTO_DB_BACKUP_ENABLED=true
AUTO_DB_BACKUP_TIME=02:00
AUTO_DB_BACKUP_KEEP=30
# Per-facility scheduled exports (default true). Set false to skip facility loop.
# SCHEDULED_FACILITY_BACKUPS=true
# Whole-database mysqldump/restore for super admin (hosting-style). Default off.
# ENABLE_FULL_DATABASE_MYSQLDUMP=false

# Optional: full path to mysql / mysqldump if backup/restore fails (PHP-FPM PATH)
# MYSQL_CLI_PATH=/usr/bin/mysql
# MYSQLDUMP_CLI_PATH=/usr/bin/mysqldump
# Set false on older MySQL/MariaDB if mysqldump errors with unknown option --no-tablespaces
# MYSQLDUMP_NO_TABLESPACES=true

# -----------------------------------------------
# Session Configuration
# -----------------------------------------------
SESSION_DRIVER=file
SESSION_LIFETIME=30
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=false
# Share session cookies across subdomains (production multi-tenant). Leave unset for local dev.
# SESSION_DOMAIN=.your-domain.com

# -----------------------------------------------
# Cache & Queue
# -----------------------------------------------
CACHE_STORE=file
CACHE_PREFIX=
QUEUE_CONNECTION=sync

# -----------------------------------------------
# Mail Configuration
# -----------------------------------------------
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="support@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------
# Logging
# -----------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# -----------------------------------------------
# Security
# -----------------------------------------------
BCRYPT_ROUNDS=12
# API bearer token lifetime (minutes). Must match TOKEN_EXPIRY_MINUTES in resources/js/services/api.js (240).
# SPA proactively refreshes 10 minutes before expiry; SESSION_LIFETIME should be >= this value in production.
SANCTUM_TOKEN_EXPIRATION=240
# Comma-separated hosts that receive Sanctum stateful (cookie) auth. Include APP_URL host and any tenant subdomains.
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:8000,::1
# Trust load balancer / reverse proxy when resolving client IP and HTTPS (production behind Forge, ALB, nginx, etc.).
# Use * on Forge or a single trusted hop; or comma-separated proxy IPs/CIDRs. Leave unset for local dev.
# TRUSTED_PROXIES=*

# -----------------------------------------------
# CORS (comma-separated list for production)
# -----------------------------------------------
# CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# -----------------------------------------------
# AWS (for SES email, S3 storage, etc.)
# -----------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

# Private upload storage. Keep PHI documents off the public disk.
DOCUMENT_LIBRARY_DISK=local
RESIDENT_DOCUMENTS_DISK="${DOCUMENT_LIBRARY_DISK}"
EMPLOYEE_DOCUMENTS_DISK="${DOCUMENT_LIBRARY_DISK}"
T_LOG_ATTACHMENTS_DISK="${DOCUMENT_LIBRARY_DISK}"
INCIDENT_ATTACHMENTS_DISK="${DOCUMENT_LIBRARY_DISK}"

# -----------------------------------------------
# Broadcasting
# -----------------------------------------------
# Recommended production: Pusher (https://dashboard.pusher.com) — no WebSocket proxy on your server.
# Alternative: reverb (self-hosted; see deployment/nginx-reverb-forge.conf — conflicts with SPA /app if misconfigured)
BROADCAST_CONNECTION=pusher

# Pusher Channels (set in dashboard; cluster e.g. mt1, us2, eu)
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# --- Optional: Laravel Reverb (local dev or advanced self-host) ---
# BROADCAST_CONNECTION=reverb
# REVERB_APP_ID=homelogic360
# REVERB_APP_KEY=homelogic360-key
# REVERB_APP_SECRET=homelogic360-secret
# REVERB_SERVER_HOST=0.0.0.0
# REVERB_SERVER_PORT=8080
# REVERB_HOST=127.0.0.1
# REVERB_PORT=8080
# REVERB_SCHEME=http
# VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
# VITE_REVERB_HOST=localhost
# VITE_REVERB_PORT=8080
# VITE_REVERB_SCHEME=http

# -----------------------------------------------
# Web Push (PWA device notifications — Profile → App push notifications)
# -----------------------------------------------
# Generate once: php artisan webpush:vapid
# Set the public key twice: VAPID_PUBLIC_KEY and VITE_VAPID_PUBLIC_KEY (same value).
# After changing VITE_*, run npm run build so the client bundle includes the key.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
VITE_VAPID_PUBLIC_KEY=

# ── Fax module ───────────────────────────────────────────────────
# Storage disk for fax PDFs (defaults to local)
FAX_DISK=local
# Default upload limit; per-facility overrides live in fax_settings.max_file_mb
FAX_MAX_FILE_MB=25
# NOTE: Provider credentials (Telnyx api key, Documo api key, etc.) are
# stored per-facility in the fax_settings table (encrypted at rest),
# NOT in .env. Configure via /fax/settings in the SPA or the Filament
# Facility resource "Fax" tab.

# -----------------------------------------------
# Production Overrides (uncomment for production)
# -----------------------------------------------
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://your-domain.com
# SESSION_SECURE_COOKIE=true
# SESSION_SAME_SITE=lax
# SESSION_LIFETIME=240
# SESSION_DOMAIN=.your-domain.com
# SANCTUM_STATEFUL_DOMAINS=your-domain.com,*.your-domain.com
# TRUSTED_PROXIES=*
# LOG_LEVEL=error
